// MarkSpec design tokens — fonts, colors, spacing.
// Source of truth: docs/spec/typography.md

// ── Fonts ──────────────────────────────────────────────────────────────

#let font-sans = ("IBM Plex Sans", "Segoe UI", "Helvetica Neue", "DejaVu Sans")
#let font-mono = ("IBM Plex Mono", "Cascadia Mono", "SF Mono", "DejaVu Sans Mono")
#let font-serif = ("IBM Plex Serif", "Georgia", "DejaVu Serif")

// ── Type scale (minor third 1.2, base 10pt) ───────────────────────────

#let size-h1 = 20pt
#let size-h2 = 16.5pt
#let size-h3 = 14pt
#let size-h4 = 12pt
#let size-body = 10pt
#let size-small = 8.5pt
#let size-code = 9pt
#let size-footer = 8pt

#let leading-body = 14pt

// ── Spacing (4pt base unit) ────────────────────────────────────────────

#let space-1 = 4pt
#let space-2 = 8pt
#let space-3 = 12pt
#let space-4 = 16pt
#let space-6 = 24pt
#let space-8 = 32pt

// ── Page layout ────────────────────────────────────────────────────────

#let page-margin = 25mm
#let page-size = "a4"

// ── Slide layout ───────────────────────────────────────────────────────

#let slide-width = 1920pt
#let slide-height = 1080pt
#let slide-margin-x = 80pt
#let slide-margin-y = 60pt
